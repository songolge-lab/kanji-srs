{
  "name": "kanji-srs-desktop",
  "version": "1.3.0",
  "description": "Kanji SRS — Kişisel Kanji Flashcard ve Aralıklı Tekrar Uygulaması",
  "main": "main.js",
  "author": "Harun",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64 --publish always",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron-updater": "^6.3.4"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.harun.kanjisrs",
    "productName": "Stacks",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "web/**/*",
      "build/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "songolge-lab",
        "repo": "kanji-srs"
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Stacks"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "build/icon.png"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "build/icon.png"
    }
  }
}
