{
  "name": "kanji-srs-desktop",
  "version": "1.0.0",
  "description": "Kanji SRS — Kişisel Kanji Flashcard ve Aralıklı Tekrar Uygulaması",
  "main": "main.js",
  "author": "Harun",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.harun.kanjisrs",
    "productName": "漢字帖 Kanji Defterim",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "web/**/*",
      "build/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Kanji Defterim"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "build/icon.png"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "build/icon.png"
    }
  }
}
